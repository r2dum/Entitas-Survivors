# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
/Source/Entitas-Survivors/[Ll]ibrary/
/Source/Entitas-Survivors/[Tt]emp/
/Source/Entitas-Survivors/[Oo]bj/
/Source/Entitas-Survivors/[Bb]uild/
/Source/Entitas-Survivors/[Bb]uilds/
/Source/Entitas-Survivors/[Ll]ogs/
/Source/Entitas-Survivors/[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/Source/Entitas-Survivors/[Mm]emoryCaptures/

# Recordings can get excessive in size
/Source/Entitas-Survivors/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /Source/Entitas-Survivors/[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/Source/Entitas-Survivors/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
/Source/Entitas-Survivors/.vs/
/Source/Entitas-Survivors/.idea
.idea/
/Source/Entitas-Survivors/.idea/

# Gradle cache directory
/Source/Entitas-Survivors/.gradle/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
mono_crash.*
/Source/Entitas-Survivors/sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics generated file
crashlytics-build.properties

# TestRunner generated files
InitTestScene*.unity*

# Third-party assets
/Source/Entitas-Survivors/Assets/Plugins/Sirenix/
/Source/Entitas-Survivors/Assets/Plugins/Sirenix.meta

# Addressables default ignores, before user customizations
/Source/Entitas-Survivors/ServerData
/Source/Entitas-Survivors/[Aa]ssets/StreamingAssets/aa*
/Source/Entitas-Survivors/[Aa]ssets/AddressableAssetsData/link.xml*
/Source/Entitas-Survivors/[Aa]ssets/Addressables_Temp*
# By default, Addressables content builds will generate addressables_content_state.bin
# files in platform-specific subfolders, for example:
# /Source/Entitas-Survivors/Assets/AddressableAssetsData/OSX/addressables_content_state.bin
/Source/Entitas-Survivors/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
/Source/Entitas-Survivors/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/Source/Entitas-Survivors/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/Source/Entitas-Survivors/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/Source/Entitas-Survivors/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests
/Source/Entitas-Survivors/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

.DS_Store
.vsconfig

# Crashlytics generated file
/Source/Entitas-Survivors/crashlytics-build.properties

# Packed Addressables
/Source/Entitas-Survivors/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

/Source/Entitas-Survivors/Assets/Plugins/Zenject/OptionalExtras/ReflectionBaking/Zenject-ReflectionBaking.csproj.meta
/Source/Entitas-Survivors/Assets/Plugins/Zenject/Source/Zenject.csproj.meta

Source/CustomGenerators/CustomGenerators/KSyndicate.CustomGenerators.Plugins/obj
Source/CustomGenerators/CustomGenerators/KSyndicate.CustomGenerators.Plugins/bin

# Temporary auto-generated Android Assets
/Source/Entitas-Survivors/[Aa]ssets/[Ss]treamingAssets/aa.meta
/Source/Entitas-Survivors/[Aa]ssets/[Ss]treamingAssets/aa/*